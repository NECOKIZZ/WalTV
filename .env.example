VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_USE_FIREBASE_EMULATORS=false

# Sui + Enoki (zkLogin via Google) configuration.
# Authentication is fully zkLogin-based; there is no Firebase Auth layer.
VITE_SUI_NETWORK=testnet
# Public Enoki API key from https://portal.enoki.mystenlabs.com.
# Use the PUBLIC key for the browser. Never put the private key in a Vite env.
VITE_ENOKI_PUBLIC_API_KEY=enoki_public_xxxxxxxxxxxxxxxx
# Google OAuth Web Client ID. Same one configured in Enoki Portal -> Auth
# Providers -> Google. The Google Cloud Console OAuth client must list
# http://localhost:5173/auth/zklogin-callback (and your prod URL) as an
# authorized redirect URI.
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Sui Move attribution package.
# Publish move/cuerate_attribution, then paste the resulting package id here.
# When unset, posting/forking still works and attribution is skipped.
VITE_CUERATE_ATTRIBUTION_PACKAGE_ID=

# Sui paid likes.
# 1 SUI = 1,000,000,000 MIST. Default demo amount below is 0.001 SUI.
VITE_ENABLE_SUI_PAID_LIKES=true
VITE_SUI_PAID_LIKE_MIST=1000000

# Walrus decentralized storage (https://docs.wal.app)
# Network selects which public publisher/aggregator to use.
# Switch to 'mainnet' for production. Testnet blobs may be wiped without warning.
VITE_WALRUS_NETWORK=testnet
# Optional: number of epochs to retain each blob. Testnet epoch ~1 day, mainnet ~2 weeks.
VITE_WALRUS_EPOCHS_TESTNET=20
VITE_WALRUS_EPOCHS_MAINNET=52
# Optional overrides for self-hosted publishers / paid aggregators.
# VITE_WALRUS_PUBLISHER_URL=
# VITE_WALRUS_AGGREGATOR_URL=
# Optional: Sui address that should own the resulting blob object.
# Required on shared mainnet publishers if you want to retain ownership
# (needed later for Move attribution and deletable blob cleanup).
# VITE_WALRUS_SEND_OBJECT_TO=
